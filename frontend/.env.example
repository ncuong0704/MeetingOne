# Tauri Code Signing Configuration

TAURI_SIGNING_PRIVATE_KEY=

# Hoặc đường dẫn file key (khuyến nghị khi dev): ví dụ .tauri/updater.key
TAURI_SIGNING_PRIVATE_KEY_PATH=

TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# Notes:
# - The key should be a single line of base64-encoded text
# - The password is used by Tauri during the signing process
# - Both values are loaded as environment variables during build
# - For CI/CD, set these as repository secrets instead of using .env
#
# In-app updater (tauri-plugin-updater):
# - Build release với createUpdaterArtifacts; đính kèm trên GitHub: latest.json, .sig, installer.
# - Endpoint mặc định: src-tauri/tauri.conf.json -> plugins.updater.endpoints (đồng bộ repo với NEXT_PUBLIC_GITHUB_REPO).
